# Local environment — copy to .env and fill in real values (never commit .env)
# Expo only exposes variables prefixed with EXPO_PUBLIC_
EXPO_PUBLIC_APP_ENV=development

# Firebase config (values come from GoogleService-Info.plist / google-services.json)
EXPO_PUBLIC_FIREBASE_API_KEY=replace_me
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_me.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=replace_me
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_me.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_me
EXPO_PUBLIC_FIREBASE_APP_ID=replace_me_ios_app_id
EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID=replace_me_android_app_id
